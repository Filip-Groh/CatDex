<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CatDex.ViewModels"
             xmlns:controls="clr-namespace:CatDex.Controls"
             x:Class="CatDex.Views.SettingsPage"
             x:DataType="viewmodels:SettingsViewModel">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Appearance" Style="{StaticResource PageTitle}"/>

            <controls:SectionBorder>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Theme" Style="{StaticResource SectionHeader}"/>
                    <Picker 
                        ItemsSource="{Binding ThemeOptions}"
                        SelectedItem="{Binding SelectedTheme}"
                        Title="Select Theme"
                        FontSize="16"/>
                </VerticalStackLayout>
            </controls:SectionBorder>

            <Label Text="Image Caching" Style="{StaticResource PageTitle}"/>

            <controls:SectionBorder>
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label 
                            Text="Favorites Only"
                            FontSize="16"
                            VerticalOptions="Center"/>
                        <Switch 
                            IsToggled="{Binding CacheAllImages}"
                            VerticalOptions="Center"/>
                        <Label 
                            Text="All Images"
                            FontSize="16"
                            VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <VerticalStackLayout 
                        Spacing="5" 
                        IsVisible="{Binding IsCaching}"
                        Margin="0,10,0,0">
                        <Label 
                            FontSize="14"
                            HorizontalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Caching images: "/>
                                    <Span Text="{Binding CachingProgress}"/>
                                    <Span Text=" / "/>
                                    <Span Text="{Binding CachingTotal}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <ProgressBar 
                            Progress="{Binding CachingProgressRatio}"
                            ProgressColor="{StaticResource Primary}"
                            HeightRequest="8"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </controls:SectionBorder>

            <Label Text="Database Statistics" Style="{StaticResource PageTitle}"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Style="{StaticResource CenteredActivityIndicator}"/>

            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
                <controls:StatCard Title="Total Cats" Value="{Binding TotalCats}"/>

                <controls:StatCard Title="Favorite Cats" Value="{Binding FavoriteCats}"/>

                <controls:StatCard Title="Created Cats" Value="{Binding CreatedCats}"/>

                <controls:StatCard Title="Total Stored Images" Value="{Binding TotalStoredImages}"/>

                <controls:StatCard Title="User Created Images" Value="{Binding UserCreatedImages}"/>

                <controls:StatCard Title="Cached Images" Value="{Binding CachedImages}"/>

                <Button Text="Delete Non-Created and Non-Favorite Cats"
                        Command="{Binding DeleteNonCreatedNonFavoriteCommand}"
                        Style="{StaticResource DangerButton}"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
