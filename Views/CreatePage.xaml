<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CatDex.ViewModels"
             xmlns:models="clr-namespace:CatDex.Models"
             xmlns:controls="clr-namespace:CatDex.Controls"
             x:Class="CatDex.Views.CreatePage"
             x:DataType="viewmodels:CreateViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Create a Custom Cat" Style="{StaticResource PageTitle}"/>

            <controls:SectionBorder>
                <VerticalStackLayout Spacing="10">

                    <Grid>
                        <Label Text="Select Image" Style="{StaticResource SectionHeader}" VerticalOptions="Center" HorizontalOptions="Start"/>
                        <controls:CircularIconButton IconSource="upload.svg"
                                                     Command="{Binding PickImageCommand}"
                                                     IsButtonEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                                     HorizontalOptions="End"/>
                    </Grid>

                    <Image 
                        Source="{Binding ImageSource}"
                        IsVisible="{Binding ImageSource, Converter={StaticResource IsNotNullConverter}}"
                        HeightRequest="200"
                        Aspect="AspectFit"
                        Margin="0,10,0,0" />

                    <HorizontalStackLayout 
                        Spacing="10"
                        Margin="0,10,0,0"
                        IsVisible="{Binding ImageSource, Converter={StaticResource IsNotNullConverter}}">
                        <Label Text="Dimensions:" Style="{StaticResource BoldInfoLabel}"/>
                        <Label Text="{Binding Width}" VerticalOptions="Center" />
                        <Label Text="x" VerticalOptions="Center" />
                        <Label Text="{Binding Height}" VerticalOptions="Center" />
                        <Label Text="px" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </controls:SectionBorder>

            <controls:SectionBorder>
                <VerticalStackLayout Spacing="10">

                    <Label Text="Select Breeds (Optional)" Style="{StaticResource SectionHeader}"/>

                    <!-- Selected Breeds List (Vertical) -->
                    <VerticalStackLayout Spacing="8">
                        <BindableLayout.ItemsSource>
                            <Binding Path="SelectedBreeds" />
                        </BindableLayout.ItemsSource>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Breed">
                                <Border 
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="12,6">
                                    <Grid>
                                        <Label 
                                            Text="{Binding Name}"
                                            VerticalOptions="Center"
                                            FontSize="14"
                                            HorizontalOptions="Start"/>
                                        <Button Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CreateViewModel}}, Path=RemoveBreedCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource SmallCloseButton}"
                                                HorizontalOptions="End"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Breed Picker (at the end) -->
                    <Picker 
                        ItemsSource="{Binding AvailableBreeds}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="Select a Breed"
                        SelectedIndexChanged="OnBreedSelected"/>
                </VerticalStackLayout>
            </controls:SectionBorder>

            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Style="{StaticResource ErrorLabel}"/>

            <Button Text="Create Cat"
                    Command="{Binding CreateCatCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryActionButton}"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Style="{StaticResource CenteredActivityIndicator}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>