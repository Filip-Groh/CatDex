<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Page Title Style -->
    <Style TargetType="Label" x:Key="PageTitle">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!-- Section Header Style -->
    <Style TargetType="Label" x:Key="SectionHeader">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- Toggle Icon Button Style (for grid/list toggle) -->
    <Style TargetType="Button" x:Key="ToggleIconButton">
        <Setter Property="WidthRequest" Value="36" />
        <Setter Property="HeightRequest" Value="36" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=Transparent}" />
    </Style>

    <!-- Transparent Icon Button Style -->
    <Style TargetType="Button" x:Key="TransparentIconButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=Black, Dark=White}" />
    </Style>

    <!-- Circular Upload Button Style -->
    <Style TargetType="Button" x:Key="CircularUploadButton" BasedOn="{StaticResource TransparentIconButton}">
        <Setter Property="WidthRequest" Value="50" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="CornerRadius" Value="25" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <!-- Small Close/Remove Button Style -->
    <Style TargetType="Button" x:Key="SmallCloseButton" BasedOn="{StaticResource TransparentIconButton}">
        <Setter Property="Text" Value="×" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="WidthRequest" Value="24" />
        <Setter Property="HeightRequest" Value="24" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Primary Action Button Style -->
    <Style TargetType="Button" x:Key="PrimaryActionButton">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Margin" Value="0,10,0,20" />
    </Style>

    <!-- Danger/Delete Button Style -->
    <Style TargetType="Button" x:Key="DangerButton">
        <Setter Property="BackgroundColor" Value="#DC3545" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Margin" Value="0,10,0,20" />
    </Style>

    <!-- Error Message Label Style -->
    <Style TargetType="Label" x:Key="ErrorLabel">
        <Setter Property="TextColor" Value="Red" />
        <Setter Property="Margin" Value="0,10,0,0" />
    </Style>

    <!-- Bold Info Label Style -->
    <Style TargetType="Label" x:Key="BoldInfoLabel">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- Centered Activity Indicator Style -->
    <Style TargetType="ActivityIndicator" x:Key="CenteredActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- Stat Value Label Style -->
    <Style TargetType="Label" x:Key="StatValueLabel">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

</ResourceDictionary>
