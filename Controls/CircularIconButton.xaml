<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatDex.Controls.CircularIconButton"
             x:Name="this">

    <Button x:Name="InnerButton"
            ImageSource="{Binding Source={x:Reference this}, Path=IconSource}"
            Command="{Binding Source={x:Reference this}, Path=Command}"
            CommandParameter="{Binding Source={x:Reference this}, Path=CommandParameter}"
            WidthRequest="{Binding Source={x:Reference this}, Path=Size}"
            HeightRequest="{Binding Source={x:Reference this}, Path=Size}"
            CornerRadius="{Binding Source={x:Reference this}, Path=CornerRadiusValue}"
            Padding="{Binding Source={x:Reference this}, Path=IconPadding}"
            IsEnabled="{Binding Source={x:Reference this}, Path=IsButtonEnabled}"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#808080}" />
</ContentView>
